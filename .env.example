# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=        # ej: -1001234567890
TELEGRAM_ADMIN_ID=          # tu user ID de Telegram (para /ahora y alertas de error)

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Horarios ────────────────────────────────────────────────────────────────
SEND_TIME=07:30             # mensaje motivacional matutino
SEND_TIME_EVENING=21:00     # check-in + encuesta nocturna
TIMEZONE=Europe/Madrid      # IANA timezone (ver README para otras zonas)

# ─── Almacenamiento ──────────────────────────────────────────────────────────
# En Railway, configura un Volume en /app/data y usa estas rutas:
HISTORY_FILE=/app/data/messages_history.json
PHRASES_FILE=/app/data/community_phrases.json
STATE_FILE=/app/data/bot_state.json

# ─── ElevenLabs (opcional) ───────────────────────────────────────────────────
# Si se configura, el bot enviará también un audio del mensaje matutino.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (español)

# ─── Logs (opcional) ─────────────────────────────────────────────────────────
# En Railway los logs van a stdout por defecto. Descomenta para archivo adicional:
# LOG_FILE=/app/data/bot.log
