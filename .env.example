# ─── Telegram ────────────────────────────────────────────────────────────────
# Token from @BotFather (format: 123456789:AABBccDDee...)
TELEGRAM_BOT_TOKEN=

# Target channel or group ID.
# Channels: usually negative with -100 prefix (e.g. -1001234567890)
# Groups: negative integer (e.g. -987654321)
# To find it: forward a message from the channel to @userinfobot
TELEGRAM_CHANNEL_ID=

# Your personal Telegram user ID (integer) for error notifications.
# Optional — leave empty to disable admin alerts.
# Find it by messaging @userinfobot
TELEGRAM_ADMIN_ID=

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Schedule ────────────────────────────────────────────────────────────────
# Time to send the daily message (24-hour HH:MM format)
SEND_TIME=07:30

# IANA timezone name. Examples: Europe/Madrid, America/Mexico_City, America/Bogota
TIMEZONE=Europe/Madrid

# ─── Storage (optional) ──────────────────────────────────────────────────────
# Path to the JSON history file. Defaults to messages_history.json in the
# working directory. Change when running in Docker with a mounted volume.
# HISTORY_FILE=/app/data/messages_history.json
